{
  "name": "nowtify",
  "version": "0.5.30",
  "description": "Nowtify - ambient JSM alert overlay. Thin screen-border glow that flashes when watched tickets cross Major Incident or SLA trigger conditions.",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "icon": "electron scripts/generate-icon.js",
    "dist": "electron-builder --mac --universal",
    "release": "electron-builder --mac --universal --publish always",
    "lint": "eslint .",
    "test": "node --test 'test/**/*.test.js'",
    "ship": "bash scripts/ship.sh patch",
    "ship:minor": "bash scripts/ship.sh minor",
    "ship:major": "bash scripts/ship.sh major",
    "dist:win": "electron-builder --win",
    "dist:all": "electron-builder --mac --universal --win"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.paulgerios.nowtify",
    "productName": "Nowtify",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "extendInfo": {
        "LSUIElement": true,
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "Nowtify OAuth Callback",
            "CFBundleURLSchemes": [
              "nowtify"
            ]
          }
        ]
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis"
        }
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "publish": {
      "provider": "github",
      "owner": "paulg7516",
      "repo": "nowtify",
      "releaseType": "release"
    }
  }
}
