{
  "name": "nowtify",
  "version": "0.1.5",
  "description": "Nowtify - ambient JSM alert overlay. Thin screen-border glow that flashes when watched tickets cross Major Incident or SLA trigger conditions.",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --enable-logging",
    "icon": "electron scripts/generate-icon.js",
    "dist": "electron-builder --mac --universal",
    "release": "electron-builder --mac --universal --publish always",
    "ship": "npm version patch --no-git-tag-version && npm run release",
    "ship:minor": "npm version minor --no-git-tag-version && npm run release",
    "ship:major": "npm version major --no-git-tag-version && npm run release"
  },
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9"
  },
  "build": {
    "appId": "com.paulgerios.nowtify",
    "productName": "Nowtify",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "identity": null,
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "publish": {
      "provider": "github",
      "owner": "paulg7516",
      "repo": "nowtify",
      "releaseType": "release"
    }
  }
}
